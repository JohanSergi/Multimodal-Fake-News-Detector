{
  "manifest_version": 3,
  "name": "AI Fake News Detector",
  "version": "1.0",
  "description": "Detect fake news articles automatically using AI",
  "permissions": ["activeTab", "scripting"],
  "host_permissions": [
    "http://127.0.0.1:8000/*",
    "<all_urls>"
  ],
  "action": {
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ]
}